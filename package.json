{
  "name": "dpla-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "yarn && node server.js --trace-deprecation",
    "clean": "rm -rf .next ./build ./coverage ./node_modules",
    "build": "yarn && NODE_ENV=production next build",
    "postbuild": "node scripts/generate-pages-sitemap.js",
    "start": "NODE_ENV=production node server.js",
    "docker:build": "docker build -t dpla-frontend .",
    "docker:clean": "docker container rm -f dpla-frontend; docker image rm -f dpla-frontend",
    "docker:run": "docker run -p 3000:3000 -d --name dpla-frontend dpla-frontend:latest",
    "docker:logs": "docker logs -f dpla-frontend",
    "analyze": "yarn && ANALYZE=true yarn build",
    "test": "node --test lib/*.test.mjs && node scripts/check-favicons.js",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1069.0",
    "@mailchimp/mailchimp_marketing": "^3.0.80",
    "@sentry/nextjs": "^10.58.0",
    "@sentry/node": "^10.58.0",
    "@sentry/profiling-node": "^10.58.0",
    "@types/mailchimp__mailchimp_marketing": "^3.0.22",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "localforage": "^1.10.0",
    "next": "^16.2.9",
    "openseadragon": "^6.0.2",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-aria-modal": "5.0.2",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-slick": "^0.31.0",
    "rehype-raw": "^7.0.0",
"slick-carousel": "^1.8.1",
    "striptags": "^3.2.0",
    "xml-formatter": "^3.7.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "eslint": "^10.5.0",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "qs": "6.14.2",
    "picomatch": "^2.3.2",
    "brace-expansion": "^5.0.5",
"postcss": "^8.5.10"
  },
  "lint-staged": {
    "*": "eslint"
  }
}
